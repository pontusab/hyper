{
  "name": "@usehyper/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Hyper core — Bun-first, AI-native API framework runtime.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/hyper.git"
  },
  "sideEffects": false,
  "files": ["src", "LICENSE", "README.md"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./bun": {
      "types": "./src/adapters/bun.ts",
      "import": "./src/adapters/bun.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit || bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "test:fuzz": "bun test src/**/*.fuzz.test.ts",
    "bench": "bun run src/__bench__/index.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.1",
    "expect-type": "1.2.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
