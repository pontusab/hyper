{
  "name": "@usehyper/testing",
  "version": "0.1.0",
  "type": "module",
  "description": "Testing helpers for Hyper apps — app.test, fakeRequest, matchers, memory stores, fuzz.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/hyper.git"
  },
  "sideEffects": false,
  "files": ["src", "LICENSE", "README.md"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./fuzz": {
      "types": "./src/fuzz.ts",
      "import": "./src/fuzz.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "import": "./src/auth.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit || bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test"
  },
  "peerDependencies": {
    "@usehyper/core": "workspace:*"
  },
  "devDependencies": {
    "@usehyper/core": "workspace:*",
    "@usehyper/log": "workspace:*",
    "@types/bun": "1.3.1",
    "expect-type": "1.2.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
