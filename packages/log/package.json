    },
    "./drizzle": {
      "types": "./src/drizzle.ts",
      "import": "./src/drizzle.ts"
    },
    "./prisma": {
      "types": "./src/prisma.ts",
      "import": "./src/prisma.ts"
    },
    "./bun-sql": {
      "types": "./src/bun-sql.ts",
      "import": "./src/bun-sql.ts"
    },
    "./ai": {
      "types": "./src/ai.ts",
      "import": "./src/ai.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit || bunx tsc --noEmit -p tsconfig.json",
    "test": "bun test"
  },
  "peerDependencies": {
    "@usehyper/core": "workspace:*"
  },
  "devDependencies": {
    "@usehyper/core": "workspace:*",
    "@types/bun": "1.3.1"
  },
