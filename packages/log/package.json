{
  "name": "@usehyper/log",
  "version": "0.1.0",
  "type": "module",
  "description": "Wide-event structured logger for Hyper — the reference plugin.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/hyper.git"
  },
