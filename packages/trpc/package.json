{
  "name": "@hyper/trpc",
  "version": "0.1.0",
  "type": "module",
  "description": "tRPC bridge — mount tRPC into Hyper, or convert a tRPC router to Hyper routes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/hyper.git"
  },
  "sideEffects": false,
  "files": ["src", "LICENSE", "README.md"],
